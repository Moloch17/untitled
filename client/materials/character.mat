// Character surface: a checker so rotation is readable at a glance. Facing is
// shown by a separate nose mesh at the body's local -Z (see scene.cpp), rather
// than by a marker placed in this UV map -- a position in the mesh cannot come
// out a quarter turn from where the maths says it should be.
//
// Generated in the shader rather than from a texture: it costs no asset, and
// the pattern stays crisp at any distance.
material {
    name : character,
    parameters : [
        { type : float3, name : colorA },
        { type : float3, name : colorB }
    ],
    requires : [ uv0 ],
    shadingModel : lit,
    culling : back
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);

        vec2 uv = getUV0();

        // u wraps the capsule, v runs top to bottom. The counts differ so the
        // squares come out roughly square in world space rather than stretched.
        float checker = mod(floor(uv.x * 8.0) + floor(uv.y * 6.0), 2.0);
        vec3 base = mix(materialParams.colorA, materialParams.colorB, checker);


        material.baseColor.rgb = base;
        material.roughness = 0.6;
        material.metallic = 0.0;
    }
}

{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux",
      "displayName": "Linux (clang + Ninja, Release)",
      "description": "Filament requires clang on Linux, so the compiler is pinned here.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "linux",
      "displayName": "Linux (clang + Ninja, Debug)",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "linux-client",
      "inherits": "linux",
      "displayName": "Linux, client only (no Postgres/libsodium needed)",
      "binaryDir": "${sourceDir}/build-client",
      "cacheVariables": { "UNTITLED_BUILD_SERVERS": "OFF" }
    },
    {
      "name": "windows",
      "displayName": "Windows (Visual Studio 2022 + vcpkg)",
      "description": "Requires VCPKG_ROOT to be set; vcpkg.json supplies libpq and libsodium.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-client",
      "inherits": "windows",
      "displayName": "Windows, client only (no vcpkg needed)",
      "binaryDir": "${sourceDir}/build-client",
      "cacheVariables": {
        "UNTITLED_BUILD_SERVERS": "OFF",
        "CMAKE_TOOLCHAIN_FILE": ""
      }
    }
  ],
  "buildPresets": [
    { "name": "linux", "configurePreset": "linux" },
    { "name": "linux-debug", "configurePreset": "linux-debug" },
    { "name": "linux-client", "configurePreset": "linux-client" },
    { "name": "windows", "configurePreset": "windows", "configuration": "Release" },
    { "name": "windows-client", "configurePreset": "windows-client", "configuration": "Release" }
  ]
}
